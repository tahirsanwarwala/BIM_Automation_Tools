<Project Sdk="Nice3point.Revit.Sdk/6.1.2">

    <PropertyGroup>
        <UseWPF>true</UseWPF>
        <DeployAddin>true</DeployAddin>
        <LaunchRevit>true</LaunchRevit>
        <IsRepackable>false</IsRepackable>
        <EnableDynamicLoading>true</EnableDynamicLoading>
        <Configurations>Debug.R22;Debug.R23;Debug.R24;Debug.R25;Debug.R26</Configurations>
        <Configurations>$(Configurations);Release.R22;Release.R23;Release.R24;Release.R25;Release.R26</Configurations>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug.R22|AnyCPU'">
      <NoWarn>1701;1702;MSB3270</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug.R23|AnyCPU'">
      <NoWarn>1701;1702;MSB3270</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug.R24|AnyCPU'">
      <NoWarn>1701;1702;MSB3270</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug.R25|AnyCPU'">
      <NoWarn>1701;1702;MSB3270</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug.R26|AnyCPU'">
      <NoWarn>1701;1702;MSB3270</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release.R22|AnyCPU'">
      <NoWarn>1701;1702;MSB3270</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release.R23|AnyCPU'">
      <NoWarn>1701;1702;MSB3270</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release.R24|AnyCPU'">
      <NoWarn>1701;1702;MSB3270</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release.R25|AnyCPU'">
      <NoWarn>1701;1702;MSB3270</NoWarn>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release.R26|AnyCPU'">
      <NoWarn>1701;1702;MSB3270</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <!-- Revit Platform -->
        <PackageReference Include="Nice3point.Revit.Toolkit" Version="$(RevitVersion).*" />
        <PackageReference Include="Nice3point.Revit.Extensions" Version="$(RevitVersion).*" />
        <PackageReference Include="Nice3point.Revit.Api.RevitAPI" Version="$(RevitVersion).*" />
        <PackageReference Include="Nice3point.Revit.Api.RevitAPIUI" Version="$(RevitVersion).*" />

        <!-- MVVM -->
        <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />

        <!-- Excel reading — no Interop required; NonCommercial license -->
        <PackageReference Include="EPPlus" Version="6.2.10" />

        <!-- Development References -->
        <PackageReference Include="JetBrains.Annotations" Version="2025.2.4" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
      <Reference Include="System.Windows.Forms" />
    </ItemGroup>
    
    <ItemGroup>
        <!-- 32x32 icons (LargeImage on ribbon buttons) -->
        <EmbeddedResource Include="Resources\Icons\SwitchBubbles32.png" />
        <EmbeddedResource Include="Resources\Icons\AddElbows32.png" />
        <EmbeddedResource Include="Resources\Icons\AlignElbows32.png" />
        <EmbeddedResource Include="Resources\Icons\MatchByView32.png" />
        <EmbeddedResource Include="Resources\Icons\MatchByModel32.png" />
        <EmbeddedResource Include="Resources\Icons\SheetsFromExcel32.png" />
        <EmbeddedResource Include="Resources\Icons\DatumTools32.png" />
        <EmbeddedResource Include="Resources\Icons\MultiSelect32.png" />

        <!-- 16x16 icons (Image on ribbon buttons) -->
        <EmbeddedResource Include="Resources\Icons\SwitchBubbles16.png" />
        <EmbeddedResource Include="Resources\Icons\AddElbows16.png" />
        <EmbeddedResource Include="Resources\Icons\AlignElbows16.png" />
        <EmbeddedResource Include="Resources\Icons\MatchByView16.png" />
        <EmbeddedResource Include="Resources\Icons\MatchByModel16.png" />
        <EmbeddedResource Include="Resources\Icons\SheetsFromExcel16.png" />
    </ItemGroup>

</Project>